---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://www.instagram.com/blakemclemore/" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Blake McLemore on Instagram</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32" fill="currentColor">
					<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
				</svg>
			</a>
			<a href="https://www.linkedin.com/in/blake-mclemore/" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Blake McLemore on LinkedIn</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="32" height="32" fill="currentColor">
					<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
				</svg>
			</a>
		</div>
	</nav>
</header>
<div class="theme-toggle-row">
	<button type="button" id="theme-toggle" class="theme-switch" aria-label="Toggle color theme" aria-pressed="false">
		<span class="theme-icon sun" aria-hidden="true">
			<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
				<circle cx="12" cy="12" r="4"></circle>
				<path d="M12 2v2"></path>
				<path d="M12 20v2"></path>
				<path d="m4.93 4.93 1.41 1.41"></path>
				<path d="m17.66 17.66 1.41 1.41"></path>
				<path d="M2 12h2"></path>
				<path d="M20 12h2"></path>
				<path d="m6.34 17.66-1.41 1.41"></path>
				<path d="m19.07 4.93-1.41 1.41"></path>
			</svg>
		</span>
		<span class="theme-track" aria-hidden="true">
			<span class="theme-thumb"></span>
		</span>
		<span class="theme-icon moon" aria-hidden="true">
			<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M12 3a7.5 7.5 0 1 0 9 9A9 9 0 1 1 12 3z"></path>
			</svg>
		</span>
	</button>
</div>
<script is:inline>
	const themeToggle = document.getElementById('theme-toggle');
	const root = document.documentElement;

	const syncToggleState = () => {
		const isDark = root.getAttribute('data-theme') === 'dark';
		if (themeToggle) {
			themeToggle.setAttribute('aria-pressed', String(isDark));
		}
	};

	if (themeToggle) {
		syncToggleState();
		themeToggle.addEventListener('click', () => {
			const nextTheme = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
			root.setAttribute('data-theme', nextTheme);
			localStorage.setItem('theme', nextTheme);
			syncToggleState();
		});
	}
</script>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--header-bg);
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
	.theme-toggle-row {
		padding: 0.4rem 1rem 0.75rem;
		display: flex;
		justify-content: flex-end;
		background: var(--header-bg);
		border-top: 1px solid var(--line-color);
	}
	.theme-switch {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font: inherit;
		color: rgb(var(--gray-dark));
		background: transparent;
		border: 0;
		padding: 0;
		cursor: pointer;
	}
	.theme-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: rgb(var(--gray));
	}
	.theme-track {
		width: 2.6rem;
		height: 1.45rem;
		border-radius: 9999px;
		background: rgb(var(--gray-light));
		border: 1px solid var(--surface-border);
		padding: 2px;
		display: inline-flex;
		align-items: center;
		transition: background-color 0.2s ease;
	}
	.theme-thumb {
		width: 1rem;
		height: 1rem;
		border-radius: 9999px;
		background: rgb(var(--gray-dark));
		transform: translateX(0);
		transition: transform 0.2s ease;
	}
	.theme-switch[aria-pressed='true'] .theme-track {
		background: var(--accent);
	}
	.theme-switch[aria-pressed='true'] .theme-thumb {
		background: #fff;
		transform: translateX(1.1rem);
	}
	.theme-switch:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}
	.theme-switch:hover .theme-icon {
		color: rgb(var(--gray-dark));
	}
	@media (max-width: 720px) {
		.theme-toggle-row {
			padding-top: 0.55rem;
		}
	}
</style>
