---
import Layout from '../layouts/BlogPost.astro';
---

<Layout title="Contact" description="Contact page" pubDate={new Date()}>
	<p>Need to reach out? Drop a line here.</p>

	<form
		name="contact"
		method="POST"
		action="/thanks"
		data-netlify="true"
		data-netlify-honeypot="bot-field"
		class="mt-8 w-full max-w-xl mx-auto space-y-6"
	>
		<p class="sr-only">
			<label>
				Don't fill this out if you're human: <input name="bot-field" type="text" />
			</label>
		</p>
		<input type="hidden" name="form-name" value="contact" />

		<div class="space-y-2">
			<label for="name" class="block text-sm font-medium">Name</label>
			<input
				id="name"
				name="name"
				type="text"
				required
				class="w-full rounded-md border border-gray-300 px-3 py-2 bg-white text-black focus:outline-none focus:ring-2 focus:ring-black/20 focus:border-black"
			/>
		</div>

		<div class="space-y-2">
			<label for="email" class="block text-sm font-medium">Email</label>
			<input
				id="email"
				name="email"
				type="email"
				required
				class="w-full rounded-md border border-gray-300 px-3 py-2 bg-white text-black focus:outline-none focus:ring-2 focus:ring-black/20 focus:border-black"
			/>
		</div>

		<div class="space-y-2">
			<label for="message" class="block text-sm font-medium">Message</label>
			<textarea
				id="message"
				name="message"
				required
				rows="6"
				class="w-full rounded-md border border-gray-300 px-3 py-2 bg-white text-black focus:outline-none focus:ring-2 focus:ring-black/20 focus:border-black"
			></textarea>
		</div>

		<button
			type="submit"
			class="inline-flex items-center justify-center rounded-md border border-black px-4 py-2 text-sm hover:bg-black hover:text-white transition-colors"
		>
			Send
		</button>
	</form>
</Layout>
